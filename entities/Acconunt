{
  "name": "Account",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Nome da conta (ex: Nubank, Carteira, Ita\u00fa)"
    },
    "type": {
      "type": "string",
      "enum": [
        "bank",
        "wallet",
        "digital",
        "investment",
        "other"
      ],
      "description": "Tipo da conta"
    },
    "icon": {
      "type": "string",
      "description": "\u00cdcone da conta"
    },
    "color": {
      "type": "string",
      "description": "Cor da conta"
    },
    "initial_balance": {
      "type": "number",
      "default": 0,
      "description": "Saldo inicial da conta"
    },
    "is_active": {
      "type": "boolean",
      "default": true
    }
  },
  "required": [
    "name",
    "type"
  ]
}